commands:
  01_add_swap:
    command: |
      if [ ! -f /swapfile ]; then
        dd if=/dev/zero of=/swapfile bs=128M count=16
        chmod 600 /swapfile
        mkswap /swapfile
        swapon /swapfile
        echo '/swapfile swap swap defaults 0 0' >> /etc/fstab
      fi

container_commands:
  01_fix_permissions:
    command: "chown -R webapp:webapp /var/app/staging"
  02_run_migrations:
    leader_only: true
    command: |
      export DATABASE_URL=$(/opt/elasticbeanstalk/bin/get-config environment --key DATABASE_URL 2>/dev/null)
      export MEDUSA_BACKEND_URL=$(/opt/elasticbeanstalk/bin/get-config environment --key MEDUSA_BACKEND_URL 2>/dev/null)
      echo "[migrate] Running custom schema migration..."
      cd /var/app/staging/.medusa/server
      node /var/app/staging/scripts/manual-migrate.js 2>&1 || echo "[migrate] Migration completed with warnings"
      if [ -n "$MEDUSA_BACKEND_URL" ]; then
        echo "[image-fix] Replacing localhost image URLs with $MEDUSA_BACKEND_URL ..."
        node -e "const{Pool}=require('pg');const p=new Pool({connectionString:process.env.DATABASE_URL});const u=process.env.MEDUSA_BACKEND_URL;p.query(\"UPDATE image SET url=REPLACE(url,'http://localhost:9000',\$1) WHERE url LIKE 'http://localhost:9000%'\",[u]).then(r=>{console.log('[image-fix] images:',r.rowCount);return p.query(\"UPDATE product SET thumbnail=REPLACE(thumbnail,'http://localhost:9000',\$1) WHERE thumbnail LIKE 'http://localhost:9000%'\",[u]);}).then(r=>{console.log('[image-fix] thumbnails:',r.rowCount);p.end();}).catch(e=>{console.error('[image-fix]',e.message);p.end();});" 2>&1
      fi
      echo "[s3-acl-fix] Patching file-s3 to disable ACL (bucket uses bucket policy)..."
      sed -i 's/ACL: file\.access === "public" ? "public-read" : "private",/\/\/ ACL disabled/g' /var/app/staging/node_modules/@medusajs/file-s3/dist/services/s3-file.js 2>/dev/null || true
      sed -i 's/ACL: fileData\.access === "public" ? "public-read" : "private",/\/\/ ACL disabled/g' /var/app/staging/node_modules/@medusajs/file-s3/dist/services/s3-file.js 2>/dev/null || true
      sed -i 's/ACL: acl,/\/\/ ACL disabled/g' /var/app/staging/node_modules/@medusajs/file-s3/dist/services/s3-file.js 2>/dev/null || true
      echo "[s3-acl-fix] Done"
      exit 0
