option_settings:
  aws:elasticbeanstalk:application:environment:
    NPM_USE_PRODUCTION: false

commands:
  01_add_swap:
    command: |
      if [ ! -f /swapfile ]; then
        dd if=/dev/zero of=/swapfile bs=128M count=16
        chmod 600 /swapfile
        mkswap /swapfile
        swapon /swapfile
        echo '/swapfile swap swap defaults 0 0' >> /etc/fstab
      fi

container_commands:
  01_install_deps:
    command: |
      cd /var/app/staging/.medusa/server && sudo npm ci --omit=dev
  02_fix_permissions:
    command: |
      sudo chown -R webapp:webapp /var/app/staging/.medusa/server/node_modules
      sudo chown -R webapp:webapp /var/app/staging/.medusa/server/src
  03_run_migrations:
    command: |
      sudo -E env DATABASE_URL=$(sudo grep DATABASE_URL /opt/elasticbeanstalk/deployment/env | cut -d= -f2-) \
      /var/app/staging/.medusa/server/node_modules/.bin/medusa db:migrate
    leader_only: true