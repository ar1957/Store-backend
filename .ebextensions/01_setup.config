option_settings:
  aws:elasticbeanstalk:application:environment:
    NPM_USE_PRODUCTION: false

commands:
  01_add_swap:
    command: |
      if [ ! -f /swapfile ]; then
        dd if=/dev/zero of=/swapfile bs=128M count=16
        chmod 600 /swapfile
        mkswap /swapfile
        swapon /swapfile
        echo '/swapfile swap swap defaults 0 0' >> /etc/fstab
      fi

container_commands:
  01_fetch_secrets:
    command: |
      aws secretsmanager get-secret-value \
        --secret-id $AWS_SECRETS_ARN \
        --region us-west-1 \
        --query SecretString \
        --output text | \
      python3 -c "
      import json, sys, os
      secrets = json.load(sys.stdin)
      env_file = open('/etc/environment', 'a')
      for k, v in secrets.items():
          env_file.write(f'{k}={v}\n')
          os.system(f'echo export {k}=\"{v}\" >> /etc/profile.d/medusa_env.sh')
      env_file.close()
      "
  02_run_migrations:
    command: "cd /var/app/staging && npx medusa db:migrate"
    leader_only: true