commands:
  01_add_swap:
    command: |
      if [ ! -f /swapfile ]; then
        dd if=/dev/zero of=/swapfile bs=128M count=16
        chmod 600 /swapfile
        mkswap /swapfile
        swapon /swapfile
        echo '/swapfile swap swap defaults 0 0' >> /etc/fstab
      fi

container_commands:
  01_fix_permissions:
    command: "chown -R webapp:webapp /var/app/staging"
  02_reset_stale_migrations:
    leader_only: true
    command: |
      cd /var/app/staging && node -e "
      const { Pool } = require('pg');

      let dbUrl = process.env.DATABASE_URL;
      if (!dbUrl) {
        try {
          const fs = require('fs');
          const env = fs.readFileSync('/var/app/staging/.env', 'utf8');
          const match = env.match(/DATABASE_URL=([^\r\n]+)/);
          if (match) dbUrl = match[1].trim();
        } catch(e) {}
      }

      if (!dbUrl) {
        console.log('[migration-check] No DATABASE_URL — skipping');
        process.exit(0);
      }

      const pool = new Pool({ connectionString: dbUrl, connectionTimeoutMillis: 5000 });

      pool.query(\"SELECT 1 FROM information_schema.tables WHERE table_schema='public' AND table_name='clinic'\")
        .then(r => {
          if (r.rows.length === 0) {
            console.log('[migration-check] clinic table missing — clearing stale migration records');
            return pool.query(\"DELETE FROM mikro_orm_migrations WHERE name LIKE 'Migration2024%'\")
              .then(() => console.log('[migration-check] Stale records cleared'))
              .catch(e => console.log('[migration-check] Could not clear (table may not exist yet):', e.message));
          } else {
            console.log('[migration-check] clinic table exists — no reset needed');
          }
        })
        .catch(e => console.log('[migration-check] DB check failed (non-fatal):', e.message))
        .finally(() => pool.end().then(() => process.exit(0)));
      " 2>&1 || true
  03_run_migrations:
    command: "npx medusa db:migrate"
    leader_only: true