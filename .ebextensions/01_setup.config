commands:
  01_add_swap:
    command: |
      if [ ! -f /swapfile ]; then
        dd if=/dev/zero of=/swapfile bs=128M count=16
        chmod 600 /swapfile
        mkswap /swapfile
        swapon /swapfile
        echo '/swapfile swap swap defaults 0 0' >> /etc/fstab
      fi

container_commands:
  01_fix_permissions:
    command: "chown -R webapp:webapp /var/app/staging"
  02_run_migrations:
    leader_only: true
    command: |
      # Get the full DATABASE_URL from EB config (not the shell env which is just hostname)
      FULL_DB_URL=$(/opt/elasticbeanstalk/bin/get-config environment --key DATABASE_URL 2>/dev/null || echo "")
      if [ -z "$FULL_DB_URL" ]; then
        echo "[migrate] Could not get DATABASE_URL from EB config"
        exit 1
      fi
      export DATABASE_URL="$FULL_DB_URL"
      # Run from the compiled server directory where medusa-config.js lives
      cd /var/app/staging/.medusa/server && npx medusa db:migrate
