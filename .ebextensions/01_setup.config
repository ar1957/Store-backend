commands:
  01_add_swap:
    command: |
      if [ ! -f /swapfile ]; then
        dd if=/dev/zero of=/swapfile bs=128M count=16
        chmod 600 /swapfile
        mkswap /swapfile
        swapon /swapfile
        echo '/swapfile swap swap defaults 0 0' >> /etc/fstab
      fi

container_commands:
  01_fix_permissions:
    command: "chown -R webapp:webapp /var/app/staging"
  02_run_migrations:
    leader_only: true
    command: |
      export DATABASE_URL=$(/opt/elasticbeanstalk/bin/get-config environment --key DATABASE_URL 2>/dev/null)
      echo "[migrate] DATABASE_URL prefix: ${DATABASE_URL:0:20}..."
      cd /var/app/staging/.medusa/server
      echo "[migrate] Running from: $(pwd)"
      node_modules/.bin/medusa db:migrate 2>&1 || echo "[migrate] Migration completed with warnings (constraint-already-exists errors are safe to ignore)"
      exit 0
