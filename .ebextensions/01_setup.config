commands:
  01_add_swap:
    command: |
      if [ ! -f /swapfile ]; then
        dd if=/dev/zero of=/swapfile bs=128M count=16
        chmod 600 /swapfile
        mkswap /swapfile
        swapon /swapfile
        echo '/swapfile swap swap defaults 0 0' >> /etc/fstab
      fi

container_commands:
  01_fix_permissions:
    command: "chown -R webapp:webapp /var/app/staging"
  02_reset_stale_migrations:
    leader_only: true
    command: |
      # If the clinic table doesn't exist, the providerIntegration migrations
      # were recorded as done but never actually ran (failed previous deploy).
      # Delete those stale records so db:migrate re-runs them.
      DB_URL=$(grep -oP 'DATABASE_URL=\K[^\s]+' /var/app/staging/.env 2>/dev/null || echo "")
      if [ -z "$DB_URL" ]; then
        echo "[migration-check] No DATABASE_URL found, skipping stale migration reset"
        exit 0
      fi
      TABLE_EXISTS=$(psql "$DB_URL" -tAc "SELECT 1 FROM information_schema.tables WHERE table_schema='public' AND table_name='clinic'" 2>/dev/null || echo "")
      if [ -z "$TABLE_EXISTS" ]; then
        echo "[migration-check] clinic table missing — clearing stale migration records for providerIntegration module"
        psql "$DB_URL" -c "DELETE FROM mikro_orm_migrations WHERE name LIKE 'Migration2024%'" 2>/dev/null || true
        echo "[migration-check] Stale records cleared. db:migrate will now run all migrations."
      else
        echo "[migration-check] clinic table exists — no reset needed"
      fi
  03_run_migrations:
    command: "npx medusa db:migrate"
    leader_only: true